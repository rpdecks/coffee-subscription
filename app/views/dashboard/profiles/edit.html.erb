<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <% persisted_avatar = @user.avatar.attached? && @user.avatar.attachment&.persisted? && @user.avatar.blob&.persisted? %>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Profile</h1>
    <p class="text-gray-600">Update your account information and password</p>
  </div>

  <%= form_with model: @user,
      url: dashboard_profile_path,
      method: :patch,
      class: "space-y-8",
      id: "profile_form",
      data: {
        controller: "avatar-crop",
        action: "submit->avatar-crop#prepareSubmission",
        avatar_crop_max_file_size_value: 5242880
      } do |form| %>
    <!-- Avatar Section -->
    <div class="bg-white border-2 border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Profile Photo</h2>

      <div class="space-y-4">
        <!-- Current Avatar Display -->
        <div class="flex items-start gap-4">
          <div class="w-24 h-24 bg-gray-200 rounded-full flex items-center justify-center overflow-hidden flex-shrink-0">
            <div class="w-full h-full" data-avatar-crop-target="existingPreview">
              <% if persisted_avatar %>
                <%= image_tag @user.avatar.variant(resize_to_fill: [96, 96]), alt: @user.full_name, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-12 h-12 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                  </svg>
                </div>
              <% end %>
            </div>

            <img alt="Selected profile photo preview" class="hidden w-full h-full object-cover" data-avatar-crop-target="livePreview">
          </div>

          <div class="flex-1">
            <p class="text-sm font-medium text-gray-700 mb-2" data-avatar-crop-target="status">
              <% if persisted_avatar %>
                Photo uploaded
              <% else %>
                No photo yet
              <% end %>
            </p>
            <p class="text-xs text-gray-600 mb-3">PNG, JPEG or WebP • Max 5 MB</p>

            <%= form.file_field :avatar,
                class: "block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-espresso file:text-cream hover:file:bg-espresso/90 cursor-pointer",
                accept: "image/png,image/jpeg,image/webp",
                data: {
                  action: "change->avatar-crop#fileChanged",
                  avatar_crop_target: "input"
                } %>

            <div class="hidden mt-3 p-3 bg-red-50 border border-red-200 rounded" data-avatar-crop-target="error">
              <p class="text-sm text-red-700"></p>
            </div>

            <div class="hidden mt-4 rounded-xl border border-gray-200 bg-stone-50/70 p-4" data-avatar-crop-target="editor">
              <div class="grid gap-5 lg:grid-cols-[240px_1fr] lg:items-center">
                <div class="flex justify-center">
                  <div class="relative h-60 w-60 overflow-hidden rounded-full bg-gray-900/10 shadow-inner ring-4 ring-white touch-none select-none"
                       data-avatar-crop-target="cropFrame"
                       data-action="pointerdown->avatar-crop#startDrag pointermove->avatar-crop#drag pointerup->avatar-crop#endDrag pointercancel->avatar-crop#endDrag">
                    <img alt="Crop your profile photo" class="absolute left-0 top-0 max-w-none" data-avatar-crop-target="cropImage">
                    <div class="pointer-events-none absolute inset-0 rounded-full ring-1 ring-black/10"></div>
                  </div>
                </div>

                <div class="space-y-4">
                  <div>
                    <p class="text-sm font-semibold text-gray-900">Zoom and crop before saving</p>
                    <p class="mt-1 text-sm text-gray-600">Drag the image to reposition it, then use the zoom control to frame your photo.</p>
                  </div>

                  <div>
                    <div class="flex items-center justify-between text-sm text-gray-700">
                      <label for="avatar_zoom">Zoom</label>
                      <span data-avatar-crop-target="zoomValue">100%</span>
                    </div>
                    <input id="avatar_zoom"
                           type="range"
                           min="1"
                           max="3"
                           step="0.01"
                           value="1"
                           class="mt-2 w-full accent-brown"
                           data-action="input->avatar-crop#zoomChanged"
                           data-avatar-crop-target="zoom">
                  </div>

                  <div class="flex items-center gap-3">
                    <button type="button"
                            class="inline-flex items-center rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 transition hover:border-gray-400 hover:bg-white"
                            data-action="avatar-crop#resetCrop">
                      Reset crop
                    </button>
                    <p class="text-xs text-gray-500">The final profile photo is saved as a square image and displayed as a circle across the site.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Remove Photo Option -->
        <% if persisted_avatar %>
          <div class="pt-2">
            <%= form.check_box :avatar_remove,
                { data: { action: "change->avatar-crop#toggleRemove", avatar_crop_target: "removeCheckbox" } },
                "true",
                "false" %>
            <%= form.label :avatar_remove, "Remove photo", class: "text-sm text-gray-600 ml-2" %>
          </div>
        <% end %>

        <!-- Avatar Errors -->
        <% if @user.errors[:avatar].any? %>
          <div class="p-3 bg-red-50 border border-red-200 rounded">
            <p class="text-sm text-red-700">
              <%= @user.errors[:avatar].first %>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Account Information Section -->
    <div class="bg-white border-2 border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Account Information</h2>

      <% if @user.errors.any? %>
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
          <h3 class="text-sm font-semibold text-red-800 mb-2">
            <%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :first_name, "First Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :first_name,
                class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none" %>
          </div>

          <div>
            <%= form.label :last_name, "Last Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :last_name,
                class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none" %>
          </div>
        </div>

        <div>
          <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.email_field :email,
              class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none",
              required: true %>
        </div>

        <div>
          <%= form.label :phone, "Phone Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.telephone_field :phone,
              class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none",
              placeholder: "(555) 123-4567" %>
        </div>
      </div>
    </div>

    <!-- Change Password Section -->
    <div class="bg-white border-2 border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-2">Change Password</h2>
      <p class="text-sm text-gray-600 mb-4">Leave blank if you don't want to change your password</p>

      <div class="space-y-4">
        <div>
          <%= form.label :current_password, "Current Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.password_field :current_password,
              class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none",
              autocomplete: "current-password",
              placeholder: "Required to save changes" %>
          <p class="mt-1 text-xs text-gray-500">We need your current password to confirm changes</p>
        </div>

        <div>
          <%= form.label :password, "New Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.password_field :password,
              class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none",
              autocomplete: "new-password",
              placeholder: "Leave blank to keep current password" %>
          <p class="mt-1 text-xs text-gray-500">Minimum 6 characters</p>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm New Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.password_field :password_confirmation,
              class: "w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:border-green focus:ring-2 focus:ring-green/20 outline-none",
              autocomplete: "new-password",
              placeholder: "Leave blank to keep current password" %>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between pt-4">
      <%= link_to "Cancel", dashboard_root_path, class: "text-gray-600 hover:text-gray-800 font-medium" %>
      <%= form.submit "Update Profile", class: "bg-brown text-white px-6 py-2 rounded-lg hover:bg-brown/90 transition-colors" %>
    </div>
  <% end %>
</div>
