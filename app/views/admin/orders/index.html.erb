<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Orders</h1>
      <p class="text-gray-600 mt-1">Manage and fulfill customer orders</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to new_admin_order_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Record Sale
      <% end %>
      <%= link_to admin_orders_path(queue: "fulfillment"), class: "inline-flex items-center gap-2 px-4 py-2 bg-amber-100 text-amber-900 rounded-lg hover:bg-amber-200 transition-colors font-medium" do %>
        Fulfillment Queue
        <span class="inline-flex min-w-6 justify-center rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-amber-900"><%= @fulfillment_count %></span>
      <% end %>
      <%= link_to admin_orders_path(format: :csv, **params.permit(:search, :status, :queue)), class: "inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Export CSV
      <% end %>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <%= link_to admin_orders_path(queue: "fulfillment"), class: "bg-white rounded-lg border border-gray-200 p-5 hover:border-amber-300 transition-colors" do %>
      <p class="text-sm font-medium text-gray-500">Fulfillment Queue</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900"><%= @fulfillment_count %></p>
      <p class="mt-2 text-sm text-gray-600">Pending, processing, and roasting orders</p>
    <% end %>

    <%= link_to admin_orders_path(status: "pending"), class: "bg-white rounded-lg border border-gray-200 p-5 hover:border-yellow-300 transition-colors" do %>
      <p class="text-sm font-medium text-gray-500">Awaiting Review</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900"><%= @status_counts["pending"] %></p>
      <p class="mt-2 text-sm text-gray-600">New paid orders that still need attention</p>
    <% end %>

    <%= link_to admin_orders_path(queue: "fulfillment", status: "roasting"), class: "bg-white rounded-lg border border-gray-200 p-5 hover:border-orange-300 transition-colors" do %>
      <p class="text-sm font-medium text-gray-500">In Production</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900"><%= @status_counts["processing"] + @status_counts["roasting"] %></p>
      <p class="mt-2 text-sm text-gray-600">Orders currently being prepared or roasted</p>
    <% end %>

    <%= link_to admin_orders_path(queue: "delivered_today"), class: "bg-white rounded-lg border border-gray-200 p-5 hover:border-green-300 transition-colors" do %>
      <p class="text-sm font-medium text-gray-500">Delivered Today</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900"><%= @delivered_today_count %></p>
      <p class="mt-2 text-sm text-gray-600">Completed handoffs and deliveries for today</p>
    <% end %>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div class="rounded-lg border border-amber-200 bg-amber-50 p-5">
      <p class="text-sm font-medium text-amber-900">Needs Attention</p>
      <p class="mt-2 text-3xl font-semibold text-amber-950"><%= @stale_fulfillment_count %></p>
      <p class="mt-2 text-sm text-amber-900">Fulfillment orders open for <%= Order::STALE_FULFILLMENT_DAYS %>+ days</p>
    </div>

    <div class="rounded-lg border border-red-200 bg-red-50 p-5">
      <p class="text-sm font-medium text-red-900">Critical Aging</p>
      <p class="mt-2 text-3xl font-semibold text-red-950"><%= @critical_fulfillment_count %></p>
      <p class="mt-2 text-sm text-red-900">Fulfillment orders open for <%= Order::CRITICAL_FULFILLMENT_DAYS %>+ days</p>
    </div>
  </div>

  <!-- Filters & Search -->
  <div class="bg-white rounded-lg border border-gray-200 p-4">
    <%= form_with url: admin_orders_path, method: :get, class: "flex flex-col md:flex-row gap-4" do |f| %>
      <!-- Search -->
      <div class="flex-1">
        <%= f.text_field :search,
            value: params[:search],
            placeholder: "Search by order number, customer name, or email...",
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <!-- Status Filter -->
      <div>
        <%= f.select :status,
            options_for_select(
              [['All Statuses', '']] + Order.statuses.keys.map { |s| [s.titleize, s] },
              params[:status]
            ),
            {},
            class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.select :queue,
            options_for_select(
              [["All Views", ""], ["Fulfillment Queue", "fulfillment"], ["Delivered Today", "delivered_today"]],
              params[:queue]
            ),
            {},
            class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Filter", class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" %>
        <%= link_to "Clear", admin_orders_path, class: "px-6 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors" %>
      </div>
    <% end %>
  </div>

  <% if params[:queue] == "fulfillment" %>
    <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
      Showing the fulfillment queue oldest-first so the longest-waiting unfulfilled orders stay at the top.
    </div>
  <% end %>

  <%= form_with url: bulk_update_status_admin_orders_path,
      method: :patch,
      class: "space-y-4",
      data: { controller: "bulk-orders" } do %>
    <%= hidden_field_tag :search, params[:search] %>
    <%= hidden_field_tag :status, params[:status] %>
    <%= hidden_field_tag :queue, params[:queue] %>
    <%= hidden_field_tag :page, params[:page] %>

    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-sm font-medium text-gray-900">Bulk Update</p>
          <p class="text-sm text-gray-500">Selected orders: <span data-bulk-orders-target="count">0</span></p>
          <p class="mt-1 text-xs text-gray-500">Use the checkboxes in the first column to select pending, processing, or roasting orders. Shipped, delivered, and cancelled orders need individual handling.</p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <%= select_tag "bulk[status]",
              options_for_select([["Choose status", ""], ["Processing", "processing"], ["Roasting", "roasting"], ["Shipped", "shipped"], ["Delivered", "delivered"], ["Cancelled", "cancelled"]]),
              class: "min-w-52 rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
          <%= submit_tag "Update Selected",
              class: "rounded-lg bg-blue-600 px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-gray-300",
              disabled: true,
              data: { bulk_orders_target: "submit" } %>
        </div>
      </div>
    </div>

  <!-- Orders Table -->
  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <% if @orders.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                <span class="sr-only">Select order</span>
                <input
                  type="checkbox"
                  class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                  data-action="bulk-orders#toggleAll"
                  data-bulk-orders-target="master">
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order #</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Next Step</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @orders.each do |order| %>
              <% row_tone = if order.critical_fulfillment?
                  'bg-red-50/60 hover:bg-red-50'
                elsif order.stale_fulfillment?
                  'bg-amber-50/60 hover:bg-amber-50'
                elsif order.pending_fulfillment?
                  'bg-amber-50/40'
                else
                  ''
                end %>
              <tr class="transition-colors <%= row_tone %>">
                <td class="px-6 py-4 whitespace-nowrap align-top">
                  <% if order.pending_fulfillment? %>
                    <%= check_box_tag "bulk[order_ids][]",
                        order.id,
                        false,
                        class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                        data: {
                          bulk_orders_target: "row",
                          action: "change->bulk-orders#refresh"
                        } %>
                  <% else %>
                    <span class="text-xs text-gray-400"><%= order.shipped? ? "Individual" : "Complete" %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= order.order_number %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= order.user.full_name %></div>
                  <div class="text-sm text-gray-500"><%= order.user.email %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= order.created_at.strftime("%b %d, %Y") %></div>
                  <div class="text-sm text-gray-500"><%= order.created_at.strftime("%l:%M %p") %></div>
                  <% if order.pending_fulfillment? %>
                    <% age_text_class = order.critical_fulfillment? ? "text-red-700" : order.stale_fulfillment? ? "text-amber-700" : "text-gray-500" %>
                    <div class="text-xs mt-1 <%= age_text_class %>">Open <%= time_ago_in_words(order.created_at) %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900">$<%= sprintf("%.2f", order.total) %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% status_colors = {
                    'pending' => 'bg-yellow-100 text-yellow-800',
                    'processing' => 'bg-blue-100 text-blue-800',
                    'roasting' => 'bg-orange-100 text-orange-800',
                    'shipped' => 'bg-purple-100 text-purple-800',
                    'delivered' => 'bg-green-100 text-green-800',
                    'cancelled' => 'bg-red-100 text-red-800'
                  } %>
                  <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_colors[order.status] || 'bg-gray-100 text-gray-800' %>">
                    <%= order.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900"><%= order.next_fulfillment_step %></div>
                  <% if order.pending_fulfillment? %>
                    <% age_badge_class = order.critical_fulfillment? ? "bg-red-100 text-red-800" : order.stale_fulfillment? ? "bg-amber-100 text-amber-800" : "bg-gray-100 text-gray-700" %>
                    <span class="mt-2 inline-flex rounded-full px-2 py-1 text-xs font-medium <%= age_badge_class %>"><%= order.fulfillment_age_label %></span>
                  <% end %>
                  <% if order.shipped? && order.tracking_number.present? %>
                    <div class="text-xs text-gray-500 mt-1">Tracking: <%= order.tracking_number %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900"><%= order.order_type.titleize %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to "View", admin_order_path(order), class: "text-blue-600 hover:text-blue-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" class="h-12 w-12 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">No orders found</h3>
        <p class="mt-2 text-gray-500">
          <% if params[:search].present? || params[:status].present? %>
            Try adjusting your filters.
          <% else %>
            Orders will appear here once customers place them.
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
  <% end %>

  <!-- Pagination -->
  <% if @orders.any? && @pagy.pages > 1 %>
    <div class="bg-white rounded-lg border border-gray-200 px-4 py-3">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="text-sm text-gray-700">
          Showing <span class="font-medium"><%= @pagy.from %></span> to <span class="font-medium"><%= @pagy.to %></span> of <span class="font-medium"><%= @pagy.count %></span> orders
        </div>
        <div class="flex items-center gap-2">
          <%== @pagy.series_nav %>
        </div>
      </div>
    </div>
  <% end %>
</div>
