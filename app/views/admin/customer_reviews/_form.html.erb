<%= form_with model: [ :admin, customer_review ], class: "space-y-6" do |f| %>
  <% if customer_review.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800">
        <%= pluralize(customer_review.errors.count, "error") %> prevented this review from being saved:
      </h3>
      <ul class="mt-2 list-disc pl-5 text-sm text-red-700 space-y-1">
        <% customer_review.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="md:col-span-2">
      <%= f.label :product_id, "Product", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :product_id,
          options_for_select([["General testimonial / About page", nil]] + products.map { |product| [product.name, product.id] }, customer_review.product_id),
          {},
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <p class="mt-1 text-sm text-gray-500">Leave this as general if the quote is about Acer Coffee overall rather than a specific product.</p>
    </div>

    <div>
      <%= f.label :customer_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :customer_name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :location, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :location, placeholder: "Portland, OR", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :headline, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :headline, placeholder: "Favorite morning ritual", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :rating, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :rating, options_for_select((1..5).map { |value| ["#{value} / 5", value] }, customer_review.rating || 5), {}, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :sort_position, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.number_field :sort_position, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <p class="mt-1 text-sm text-gray-500">Lower numbers appear first on product and about-page review lists.</p>
    </div>

    <div class="md:col-span-2">
      <%= f.label :body, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :body, rows: 6, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="md:col-span-2 space-y-3">
      <label class="flex items-center gap-3">
        <%= f.check_box :approved, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
        <span class="text-sm text-gray-900">Approved for public display</span>
      </label>

      <label class="flex items-center gap-3">
        <%= f.check_box :featured_on_about, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
        <span class="text-sm text-gray-900">Highlight on the About page</span>
      </label>
    </div>
  </div>

  <div class="flex items-center justify-between pt-6 border-t border-gray-200">
    <%= link_to "Cancel", admin_customer_reviews_path(product_id: customer_review.product_id.presence), class: "px-6 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors" %>
    <%= f.submit class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
  </div>
<% end %>