<div class="space-y-6">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Customer Reviews</h1>
      <p class="text-gray-600 mt-1">Approve product reviews and feature selected testimonials on the About page.</p>
    </div>
    <%= link_to "Add Review", new_admin_customer_review_path(product_id: params[:product_id]), class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <%= form_with url: admin_customer_reviews_path, method: :get, class: "grid grid-cols-1 md:grid-cols-4 gap-4", local: true do |f| %>
      <div>
        <%= f.label :product_id, "Product", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :product_id,
            options_for_select([["All reviews", nil], ["General testimonials", "general"]] + @products.map { |product| [product.name, product.id] }, params[:product_id]),
            {},
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg" %>
      </div>

      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :status,
            options_for_select([["All statuses", nil], ["Pending", "pending"], ["Approved", "approved"], ["Featured on About", "featured"]], params[:status]),
            {},
            class: "w-full px-4 py-2 border border-gray-300 rounded-lg" %>
      </div>

      <div class="md:col-span-2 flex items-end gap-3">
        <%= f.submit "Filter", class: "px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors" %>
        <%= link_to "Reset", admin_customer_reviews_path, class: "px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <% if @customer_reviews.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Reviewer</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Context</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Review</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white">
            <% @customer_reviews.each do |review| %>
              <tr>
                <td class="px-6 py-4 align-top">
                  <div class="font-medium text-gray-900"><%= review.customer_name %></div>
                  <% if review.location.present? %>
                    <div class="text-sm text-gray-500"><%= review.location %></div>
                  <% end %>
                  <div class="text-sm text-gray-500 mt-1">Rated <%= review.rating %> / 5</div>
                </td>
                <td class="px-6 py-4 align-top">
                  <% if review.product.present? %>
                    <div class="text-sm font-medium text-gray-900"><%= review.product.name %></div>
                    <div class="text-xs text-gray-500">Product review</div>
                  <% else %>
                    <div class="text-sm font-medium text-gray-900">General testimonial</div>
                    <div class="text-xs text-gray-500">Brand / company review</div>
                  <% end %>
                </td>
                <td class="px-6 py-4 align-top">
                  <% if review.headline.present? %>
                    <div class="text-sm font-semibold text-gray-900"><%= review.headline %></div>
                  <% end %>
                  <div class="text-sm text-gray-700 mt-1"><%= truncate(review.body, length: 160) %></div>
                </td>
                <td class="px-6 py-4 align-top space-y-2">
                  <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold <%= review.approved? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                    <%= review.approved? ? 'Approved' : 'Pending' %>
                  </span>
                  <% if review.featured_on_about? %>
                    <div>
                      <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-800">About page</span>
                    </div>
                  <% end %>
                </td>
                <td class="px-6 py-4 align-top">
                  <div class="flex flex-wrap gap-3 text-sm">
                    <%= link_to "Edit", edit_admin_customer_review_path(review), class: "text-blue-600 hover:text-blue-800" %>
                    <%= button_to(review.approved? ? "Unapprove" : "Approve", toggle_approval_admin_customer_review_path(review, product_id: params[:product_id]), method: :patch, class: "text-amber-600 hover:text-amber-800") %>
                    <%= button_to(review.featured_on_about? ? "Unfeature" : "Feature on About", toggle_about_featured_admin_customer_review_path(review, product_id: params[:product_id]), method: :patch, class: "text-indigo-600 hover:text-indigo-800") %>
                    <%= button_to "Delete", admin_customer_review_path(review, product_id: params[:product_id]), method: :delete, data: { turbo_confirm: "Delete this review?" }, class: "text-red-600 hover:text-red-800" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500">No reviews match the current filters.</p>
      </div>
    <% end %>
  </div>
</div>