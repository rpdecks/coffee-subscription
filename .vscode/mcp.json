{
  "servers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "coffee-tools": {
      "type": "stdio",
      "command": "node",
      "args": ["scripts/mcp/coffee-tools.mjs"],
      "env": {
        "COFFEE_MCP_REPO_ROOT": "${workspaceFolder}"
      }
    }
  }
}